# One process/database represents one Robinhood network.
CHAIN_ID=46630
DATABASE_URL=postgresql://hoodliquid_oracle:change-me@127.0.0.1:5432/hoodliquid_oracle_testnet
POSTGRES_PASSWORD=change-me
PORT=8080
HOST=127.0.0.1
LOG_LEVEL=info
PG_SSL=false
PG_POOL_MAX=10

# Production ingestion cadence and acceptance.
ORACLE_SCRAPE_INTERVAL_MS=60000
ORACLE_MARK_MAX_AGE_SECONDS=1800
ORACLE_SOURCE_QUORUM=1
ORACLE_MAX_SOURCE_DEVIATION_BPS=3000
ORACLE_MARKETS=ALL
ORACLE_SCRAPE_CONCURRENCY=22

# TCGPlayer source. Playwright requires both settings exactly as shown.
ORACLE_TCGPLAYER_SOURCE=playwright
ORACLE_TCGPLAYER_SCRAPING_PERMISSION_CONFIRMED=false
ORACLE_HEADLESS=true

# API mode alternative. Prefer a bearer token supplied by your own approved use.
# TCGPLAYER_BEARER_TOKEN=
# TCGPLAYER_PUBLIC_KEY=
# TCGPLAYER_PRIVATE_KEY=

# PokeTrace is optional corroboration.
# POKETRACE_API_KEY=
ORACLE_PRIMARY_SOURCE=tcgplayer
ORACLE_POKETRACE_POLL_INTERVAL_MS=900000
ORACLE_POKETRACE_MAX_AGE_SECONDS=1800
ORACLE_POKETRACE_USE_LISTINGS=false

# Testnet may consume the public PokeLiquid PL500 observation.
# Mainnet must use constituents and requires 500 complete mappings with 8 snapshots.
ORACLE_PL500_SOURCE=pokeliquid-api
ORACLE_POKELIQUID_BASE_URL=https://www.pokeliquid.xyz/api/keeper
ORACLE_POKELIQUID_MAX_AGE_SECONDS=900
